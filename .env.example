# AI Product Studio — environment variables
#
# Most of this app needs NO server-side env vars to run or deploy: the
# real LLM integrations (Pipeline Lab v3, the Ad Copy Generation test
# bench, Product's AI Assist) are all BYOK (Bring Your Own Key) and
# store the user's Anthropic/OpenAI key in the browser's localStorage
# via the app's own Настройки (Settings) screen — never in server env
# vars, never sent anywhere but directly to api.anthropic.com /
# api.openai.com (OpenAI via /api/openai-proxy, a stateless relay, only
# because OpenAI doesn't send CORS headers for direct browser calls).
# See CLAUDE.md §8.1.1 and src/shared/llm/browser-direct-provider.ts.
#
# The two vars below back a SEPARATE, currently-unused-in-the-UI path:
# src/shared/llm/provider-registry.ts's real OpenAI-compatible provider
# for the Production Pipeline Runtime (server-side, non-Mock). Not
# required for `npm run dev`/`npm run build`/deploying — only needed if
# you wire a screen to that runtime path with a real (non-Mock) provider.

# OpenAI API key for the server-side Production Pipeline Runtime provider
# (src/shared/llm/provider-registry.ts). Optional — falls back to the
# Mock LLM Provider when unset.
OPENAI_API_KEY=

# Override the OpenAI-compatible base URL (e.g. for an Azure OpenAI or
# self-hosted OpenAI-compatible endpoint). Optional, defaults to
# https://api.openai.com/v1.
OPENAI_BASE_URL=
